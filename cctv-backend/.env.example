# ===============================
# Backend environment template
# Copy this file to `.env` and edit values as needed.
# ===============================

# MongoDB URI (local machine example)
MONGODB_URI=mongodb://127.0.0.1:27017

# MongoDB database name for this project
MONGODB_DB_NAME=cctv

# Keep uploaded files after processing for history/audit.
# true  -> auto-delete uploads after processing
# false -> keep uploads on disk
AUTO_DELETE_UPLOADS=false

# Remote Mongo example (commented):
# MONGODB_URI=mongodb://<username>:<password>@<MONGO_HOST_IP>:27017/?authSource=admin
